# Maia SDK — publishing credentials
# Copy to .env and fill in your tokens. Never commit .env.

# PyPI — used by `twine upload` and publish.yml
TWINE_USERNAME=__token__
TWINE_PASSWORD=pypi-your-token-here

# npm — used by `npm publish` and publish.yml
# Generate at: https://www.npmjs.com/settings/tokens
NPM_TOKEN=npm_your-token-here
{
  "name": "@maia/brain",
  "version": "0.1.0",
  "description": "Brain orchestration runtime — team assembly, review loops, conflict resolution",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@maia/acp": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "keywords": ["ai", "agent", "brain", "orchestration", "multi-agent", "maia"],
  "author": "Maia AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maia-sdk/maia"
  }
}

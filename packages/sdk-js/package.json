{
  "name": "@maia/sdk",
  "version": "0.1.0",
  "description": "Maia SDK — the collaboration and observability layer for AI agents. One install, everything you need.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./theatre": {
      "import": "./dist/theatre.mjs",
      "require": "./dist/theatre.js",
      "types": "./dist/theatre.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist", "src"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts src/theatre.ts --format cjs,esm --dts --external react",
    "dev": "tsup src/index.ts src/theatre.ts --format cjs,esm --dts --watch --external react",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@maia/acp": "workspace:*",
    "@maia/teamchat": "workspace:*",
    "@maia/theatre": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "ai", "agent", "protocol", "multi-agent", "collaboration",
    "observability", "visualization", "theatre", "acp", "maia",
    "langchain", "crewai", "autogen"
  ],
  "author": "Maia AI",
  "license": "MIT",
  "homepage": "https://maia.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/maia-sdk/maia"
  }
}

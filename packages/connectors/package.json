{
  "name": "@maia/connectors",
  "version": "0.1.0",
  "description": "50+ pre-built connectors for AI agents — Gmail, Slack, Jira, GitHub, and more",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": ["dist", "src"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@maia/acp": "workspace:*"
  },
  "peerDependencies": {
    "@aws-sdk/client-lambda": ">=3.0.0",
    "@aws-sdk/client-s3": ">=3.0.0",
    "pg": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-lambda": { "optional": true },
    "@aws-sdk/client-s3": { "optional": true },
    "pg": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "keywords": ["ai", "agent", "connectors", "gmail", "slack", "jira", "github", "maia"],
  "author": "Maia AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maia-sdk/maia"
  }
}
{
  "name": "@maia/cli",
  "version": "0.1.0",
  "description": "Maia CLI — stream, replay, validate, emit, init, and serve ACP agent events from the terminal",
  "bin": {
    "maia": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/cli.ts --format cjs --target node18 --clean",
    "dev": "tsup src/cli.ts --format cjs --target node18 --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@maia/acp": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "acp",
    "maia"
  ],
  "author": "Maia AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maia-sdk/maia"
  }
}


{
  "name": "@maia/computer-use",
  "version": "0.1.0",
  "description": "Browser automation for AI agents — Playwright wrapper that emits ACP events",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@maia/acp": "workspace:*"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "playwright": "^1.44.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "keywords": [
    "ai",
    "agent",
    "browser",
    "automation",
    "computer-use",
    "playwright",
    "maia"
  ],
  "author": "Maia AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maia-sdk/maia"
  }
}
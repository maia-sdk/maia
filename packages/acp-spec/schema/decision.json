{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ACP Decision",
  "type": "object",
  "required": ["decision_id", "agent_id", "category", "summary"],
  "properties": {
    "decision_id": { "type": "string" },
    "step_index": { "type": "integer" },
    "agent_id": { "type": "string" },
    "category": {
      "type": "string",
      "enum": ["planning", "routing", "tool_selection", "source_selection", "review", "finalization"]
    },
    "summary": { "type": "string" },
    "options": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["option_id", "label"],
        "properties": {
          "option_id": { "type": "string" },
          "label": { "type": "string" },
          "score": { "type": "number" },
          "rationale": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "chosen_option_id": { "type": "string" },
    "reasoning": { "type": "string" },
    "related_event_ids": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}

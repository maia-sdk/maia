{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maia.ai/acp/v1/handoff.json",
  "title": "ACP Handoff",
  "description": "Transfer task ownership, context, and constraints from one agent to another.",
  "type": "object",
  "required": ["from", "to", "task"],
  "properties": {
    "from": {
      "type": "string",
      "pattern": "^agent://",
      "description": "Agent transferring the task."
    },
    "to": {
      "type": "string",
      "pattern": "^agent://",
      "description": "Agent receiving the task."
    },
    "task": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "task_id": {
          "type": "string",
          "description": "Stable task identifier shared across messages, reviews, and execution events."
        },
        "thread_id": {
          "type": "string",
          "description": "Conversation thread associated with this handoff."
        },
        "description": {
          "type": "string",
          "description": "What the receiving agent should do."
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Requirements or limits on the work."
        },
        "definition_of_done": {
          "type": "string",
          "description": "What 'complete' looks like."
        },
        "deadline_seconds": {
          "type": "integer",
          "minimum": 1,
          "description": "Optional time budget in seconds."
        },
        "priority": {
          "type": "string",
          "enum": ["low", "normal", "high", "critical"],
          "default": "normal"
        },
        "owner_agent_id": {
          "type": "string",
          "description": "Agent currently expected to own the task."
        },
        "status": {
          "type": "string",
          "enum": ["proposed", "accepted", "in_progress", "blocked", "completed", "rejected"]
        },
        "blockers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Current blockers preventing completion."
        }
      },
      "additionalProperties": true
    },
    "handoff_id": {
      "type": "string",
      "description": "Stable handoff identifier."
    },
    "status": {
      "type": "string",
      "enum": ["proposed", "accepted", "in_progress", "blocked", "completed", "rejected"]
    },
    "requires_ack": {
      "type": "boolean",
      "description": "Whether the receiving agent is expected to acknowledge the handoff."
    },
    "accepted_by": {
      "type": "string",
      "description": "Agent that accepted the handoff."
    },
    "declined_reason": {
      "type": "string",
      "description": "Reason the handoff was rejected or declined."
    },
    "context": {
      "type": "object",
      "description": "Accumulated context from prior steps — findings, decisions, artifacts.",
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "artifact.json" },
      "default": [],
      "description": "Work products being transferred."
    },
    "prior_steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "agent_id": { "type": "string" },
          "summary": { "type": "string" },
          "status": { "type": "string", "enum": ["completed", "partial", "failed"] }
        }
      },
      "description": "Summary of what happened before this handoff."
    }
  },
  "additionalProperties": false
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ACP Challenge",
  "type": "object",
  "required": ["challenge_id", "claim_id", "challenger", "target_agent_id", "reason", "status"],
  "properties": {
    "challenge_id": { "type": "string" },
    "claim_id": { "type": "string" },
    "challenger": { "type": "string" },
    "target_agent_id": { "type": "string" },
    "reason": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["open", "defended", "retracted", "resolved"]
    },
    "requested_action": {
      "type": "string",
      "enum": ["defend", "retract", "reframe"]
    },
    "claim_excerpt": { "type": "string" },
    "thread_id": { "type": "string" },
    "task_id": { "type": "string" },
    "task_title": { "type": "string" }
  },
  "additionalProperties": false
}

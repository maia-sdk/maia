{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maia.ai/acp/v1/provenance-graph.json",
  "title": "ACP Provenance Graph",
  "description": "Read-only provenance graph for claims, sources, and contradictions within an agent run.",
  "type": "object",
  "required": ["graph_id", "run_id", "claims", "contradictions"],
  "properties": {
    "graph_id": {
      "type": "string",
      "description": "Stable identifier for this provenance graph."
    },
    "run_id": {
      "type": "string",
      "description": "Run identifier associated with the graph."
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_id", "text", "agent_id", "tier", "confidence", "source_refs", "supports", "contradicts"],
        "properties": {
          "claim_id": { "type": "string" },
          "text": { "type": "string" },
          "agent_id": { "type": "string", "pattern": "^agent://" },
          "tier": {
            "type": "string",
            "enum": ["verified", "supported", "inferred", "unverified"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["source_id", "kind"],
              "properties": {
                "source_id": { "type": "string" },
                "kind": {
                  "type": "string",
                  "enum": ["url", "document", "artifact", "message", "reasoning"]
                },
                "title": { "type": "string" },
                "uri": { "type": "string" },
                "artifact_id": { "type": "string" },
                "event_id": { "type": "string" },
                "excerpt": { "type": "string" },
                "published_at": { "type": "string", "format": "date-time" },
                "accessed_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": true
            }
          },
          "supports": {
            "type": "array",
            "items": { "type": "string" }
          },
          "contradicts": {
            "type": "array",
            "items": { "type": "string" }
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    },
    "contradictions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["contradiction_id", "claim_a_id", "claim_b_id", "status"],
        "properties": {
          "contradiction_id": { "type": "string" },
          "claim_a_id": { "type": "string" },
          "claim_b_id": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["unresolved", "resolved", "dismissed"]
          },
          "resolution_summary": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

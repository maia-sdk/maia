{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maia.ai/acp/v1/artifact.json",
  "title": "ACP Artifact",
  "description": "A work product passed between agents — a draft, dataset, report, code, etc.",
  "type": "object",
  "required": ["artifact_id", "kind", "content"],
  "properties": {
    "artifact_id": {
      "type": "string",
      "description": "Unique identifier for this artifact."
    },
    "kind": {
      "type": "string",
      "enum": ["text", "markdown", "json", "csv", "html", "code", "image", "pdf", "url", "binary"],
      "description": "The type of content."
    },
    "title": {
      "type": "string",
      "description": "Human-readable title."
    },
    "content": {
      "type": "string",
      "description": "The artifact content (text) or base64-encoded data (binary/image)."
    },
    "content_url": {
      "type": "string",
      "format": "uri",
      "description": "Alternative: URL to fetch the content instead of inline."
    },
    "mime_type": {
      "type": "string",
      "description": "MIME type (e.g., 'text/markdown', 'application/json')."
    },
    "size_bytes": {
      "type": "integer",
      "minimum": 0,
      "description": "Size of the content in bytes."
    },
    "checksum": {
      "type": "string",
      "description": "SHA-256 hash for integrity verification."
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Arbitrary metadata (source, page numbers, etc.)."
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "Version number — increments when an artifact is revised."
    },
    "parent_artifact_id": {
      "type": "string",
      "description": "Reference to the previous version of this artifact."
    }
  },
  "additionalProperties": false
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maia.ai/acp/v1/activity.json",
  "title": "ACP Activity Event",
  "description": "Live stream of work happening — what an agent is doing right now.",
  "type": "object",
  "required": ["agent_id", "activity"],
  "properties": {
    "agent_id": {
      "type": "string",
      "pattern": "^agent://",
      "description": "Agent performing the activity."
    },
    "activity": {
      "type": "string",
      "enum": [
        "thinking",
        "searching",
        "reading",
        "writing",
        "browsing",
        "coding",
        "analyzing",
        "tool_calling",
        "waiting",
        "reviewing",
        "idle",
        "error"
      ],
      "description": "Current activity type."
    },
    "detail": {
      "type": "string",
      "description": "Human-readable description (e.g., 'Searching Google for pricing data')."
    },
    "tool": {
      "type": "object",
      "properties": {
        "tool_id": { "type": "string" },
        "tool_name": { "type": "string" },
        "connector_id": { "type": "string" },
        "input_summary": { "type": "string" },
        "output_summary": { "type": "string" },
        "status": { "type": "string", "enum": ["started", "running", "completed", "failed"] }
      },
      "description": "Tool call details if activity is 'tool_calling'."
    },
    "browser": {
      "type": "object",
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "title": { "type": "string" },
        "screenshot_url": { "type": "string", "format": "uri" },
        "action": { "type": "string", "enum": ["navigate", "click", "type", "scroll", "extract"] }
      },
      "description": "Browser session details if activity is 'browsing'."
    },
    "progress": {
      "type": "object",
      "properties": {
        "current": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 },
        "percentage": { "type": "number", "minimum": 0, "maximum": 100 }
      },
      "description": "Progress indicator for long-running activities."
    },
    "cost": {
      "type": "object",
      "properties": {
        "tokens_used": { "type": "integer" },
        "cost_usd": { "type": "number" },
        "model": { "type": "string" }
      },
      "description": "Running cost for this activity."
    }
  },
  "additionalProperties": false
}

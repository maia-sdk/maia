{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maia.ai/acp/v1/message.json",
  "title": "ACP Message",
  "description": "One agent sends structured content to another agent.",
  "type": "object",
  "required": ["from", "to", "intent", "content"],
  "properties": {
    "from": {
      "type": "string",
      "pattern": "^agent://",
      "description": "Sender agent URI."
    },
    "to": {
      "type": "string",
      "pattern": "^agent://",
      "description": "Recipient agent URI. Use 'agent://broadcast' for all agents in the run."
    },
    "intent": {
      "type": "string",
      "enum": ["propose", "challenge", "clarify", "review", "handoff", "summarize", "agree", "escalate"],
      "description": "The communication intent behind this message."
    },
    "content": {
      "type": "string",
      "description": "The message text."
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "artifact.json" },
      "default": [],
      "description": "Attached work products."
    },
    "context": {
      "type": "object",
      "properties": {
        "message_id": { "type": "string" },
        "run_id": { "type": "string" },
        "step": { "type": "string" },
        "thread_id": { "type": "string" },
        "in_reply_to": { "type": "string" },
        "task_id": { "type": "string" },
        "task_title": { "type": "string" },
        "handoff_id": { "type": "string" },
        "review_id": { "type": "string" },
        "channel": {
          "type": "string",
          "enum": ["direct", "thread", "broadcast"]
        },
        "mentions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requires_ack": { "type": "boolean" },
        "delivery_status": {
          "type": "string",
          "enum": ["draft", "queued", "sent", "delivered", "acknowledged", "failed"]
        },
        "acked_by": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true,
      "description": "Contextual metadata for threading and routing."
    },
    "thinking": {
      "type": "string",
      "description": "Optional visible reasoning the agent wants to share (thinking out loud)."
    },
    "mood": {
      "type": "string",
      "enum": ["neutral", "confident", "uncertain", "excited", "concerned", "focused"],
      "description": "Agent's current state — used by Theatre for visual cues."
    }
  },
  "additionalProperties": false
}
